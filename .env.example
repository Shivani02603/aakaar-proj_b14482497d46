# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL in production; tests/demo use SQLite automatically via TESTING=1
DATABASE_URL=postgresql://user:password@localhost:5432/appdb

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_HOURS=24

# ── CORS / frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# ── AI provider (any OpenAI-compatible API — switch by config, no code changes) ─
# Default: OpenAI. Just set the key:
OPENAI_API_KEY=sk-...

# Chat/answering LLM:
#   OpenAI:  leave LLM_BASE_URL empty,                    RUNTIME_LLM=gpt-4o
#   Groq:    LLM_BASE_URL=https://api.groq.com/openai/v1  RUNTIME_LLM=llama-3.3-70b-versatile  LLM_API_KEY=gsk_...
#   Gemini:  LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  RUNTIME_LLM=gemini-2.0-flash  LLM_API_KEY=AIza...
LLM_BASE_URL=
LLM_API_KEY=
RUNTIME_LLM=gpt-4o

# Embeddings (Groq has NO embeddings API — pair Groq chat with OpenAI/Gemini embeddings):
#   OpenAI:  leave EMBEDDING_BASE_URL empty,  EMBEDDING_MODEL=text-embedding-3-small
#   Gemini:  EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  EMBEDDING_MODEL=text-embedding-004
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=5
